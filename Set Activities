# Set Activities

# Activity 1: Remove Duplicates
numbers = [1, 2, 2, 3, 4, 4, 5]

# Convert to set and print unique values
unique_numbers = set(numbers)
print("Activity 1 - Unique numbers:", unique_numbers)


# Activity 2: Add and Remove
fruits = {"apple", "banana"}

# Add "orange"
fruits.add("orange")

# Remove "banana"
fruits.remove("banana")

print("Activity 2 - Updated fruits:", fruits)


# Activity 3: Set Operations
A = {1, 2, 3}
B = {3, 4, 5}

# Union
union_result = A.union(B)

# Intersection
intersection_result = A.intersection(B)

print("Activity 3 - Union:", union_result)
print("Activity 3 - Intersection:", intersection_result)


# Activity 4: Common Students
classA = {"John", "Ana", "Mark"}
classB = {"Ana", "Mark", "Liza"}

# Students in BOTH classes (intersection)
both_classes = classA.intersection(classB)

# ALL students (union)
all_students = classA.union(classB)

print("Activity 4 - Students in both classes:", both_classes)
print("Activity 4 - All students:", all_students)
